# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.dashurai.com

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://www.dashurai.com

# Security Headers
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE_MAX_SIZE=15728640  # 15MB
LOG_FILE_BACKUP_COUNT=10
ERROR_LOG_FILE_MAX_SIZE=15728640  # 15MB
ERROR_LOG_FILE_BACKUP_COUNT=10
SECURITY_LOG_FILE_MAX_SIZE=5242880  # 5MB
SECURITY_LOG_FILE_BACKUP_COUNT=5
API_LOG_FILE_MAX_SIZE=10485760  # 10MB
API_LOG_FILE_BACKUP_COUNT=5
